      "runeInsights": {
        "insights": {
          "grasp-insight": {
            "insightTitle": "Survive Your Long CDs",
            "id": "grasp-insight",
            "runeId": 8437,
            "tree": "Resolve",
            "insight": "Ambessa's early game is on the weaker side because her cooldowns are so long. That's why you need <ScRuneInline runeIdentifier=\"Grasp of the Undying\" /> to help you sustain and trade in lane.\\n\\n* Timing <ScRuneInline runeIdentifier=\"Grasp of the Undying\" /> around your <ScAbilityInline_v2 spellKey=\"W\" /> cooldown + <ScRuneInline runeIdentifier=\"Shield Bash\" /> actually hits like a truck\\n* Avoid extended trades unless you're already hard-winning"
          },
          "revitalize-unflinching-insight": {
            "insight": "The only decision you need to make in your runes is whether to take <ScRuneInline runeIdentifier=\"Revitalize\" /> or <ScRuneInline runeIdentifier=\"Unflinching\" />.\\n\\n* <span className=\"tip-highlight\"><ScRuneInline runeIdentifier=\"Revitalize\" /></span> provides great scaling for Ambessa's <ScAbilityInline_v2 spellKey=\"W\" /> shield, her healing from <ScAbilityInline_v2 spellKey=\"R\" />'s omnivamp, and <ScItemInline itemName=\"Eclipse\" /> shield\\n* <span className=\"tip-highlight\"><ScRuneInline runeIdentifier=\"Unflinching\" /></span> is better in very difficult matchups, most hard matchups have slows / stuns / knockups, and the extra 10 armor / MR lets you play aggressively or survive lane",
            "runeId2": 8242,
            "tree": "Resolve",
            "runeId": 8453,
            "id": "revitalize-unflinching-insight",
            "insightTitle": "Your Only Rune Decision"
          },
          "second-wind-insight": {
            "insightTitle": "Low HP Pays You Back",
            "runeId": 8444,
            "id": "second-wind-insight",
            "insight": "Ambessa is one of the best users of <ScRuneInline runeIdentifier=\"Second Wind\" /> because your early trades usually end up with you getting low, giving you ==higher== ==regen== ==value.==\\n\\n* While being low for most champs is very bad, it can be good for Ambessa her clutch factor is insane with <ScAbilityInline_v2 spellKey=\"W\" />'s shielding + damage\\n* If both top laners are low, Ambessa is able to win the all-in, similar to how <ScChampionInline championId=\"Olaf\" /> and <ScChampionInline championId=\"Warwick\" /> operate",
            "tree": "Resolve"
          }
        },
